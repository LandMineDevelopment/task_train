{
  "project_root": "..",
  "agents": [
    { "name": "Conductor", "descr": "Technical lead / orchestrator", "command": "agent-scripts/opencode_agent.sh", "max_concurrent": 3 },
    { "name": "Coder", "descr": "Implements features and fixes bugs", "command": "agent-scripts/opencode_agent.sh", "max_concurrent": 2 },
    { "name": "Tester", "descr": "Writes and runs tests", "command": "agent-scripts/opencode_agent.sh", "max_concurrent": 2 },
    { "name": "Explorer", "descr": "Researches codebase", "command": "agent-scripts/opencode_agent.sh", "max_concurrent": 3 },
    { "name": "Reviewer", "descr": "Reviews code quality", "command": "agent-scripts/opencode_agent.sh", "max_concurrent": 2 },
    { "name": "Manager", "descr": "Internal orchestrator", "command": "agent-scripts/opencode_agent.sh", "max_concurrent": 3 }
  ],
  "db": {
    "host": "localhost",
    "port": 5432,
    "dbname": "task_train",
    "user": "CHANGE_ME"
