############
# Task Train Supabase - Self-Hosted Configuration
#
# Copy to .env and change all secrets before starting:
#   cp .env.example .env
#
# Generate secrets with:
#   openssl rand -base64 32   # for POSTGRES_PASSWORD, JWT_SECRET
#   openssl rand -base64 24   # for PG_META_CRYPTO_KEY
#   openssl rand -base64 48   # for SECRET_KEY_BASE
#   openssl rand -hex 16      # for VAULT_ENC_KEY
#   openssl rand -hex 8       # for REALTIME_DB_ENC_KEY
#   openssl rand -hex 16      # for S3_PROTOCOL_ACCESS_KEY_ID
#   openssl rand -hex 32      # for S3_PROTOCOL_ACCESS_KEY_SECRET
############

